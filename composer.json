{
    "name": "hval/nexi-php",
    "description": "PHP library for Nexi XPay payment gateway (Hosted Payment Page)",
    "type": "library",
    "license": "MIT",
    "keywords": ["nexi", "xpay", "payment", "gateway", "hpp", "hosted-payment-page"],
    "authors": [
        {
            "name": "Hermann Vallieri",
            "email": "hermann@vallieri.email"
        }
    ],
    "require": {
        "php": ">=7.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0|^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^2.19",
        "nyholm/psr7": "^1.0",
        "phpunit/phpunit": "^8.0"
    },
    "suggest": {
        "nyholm/psr7": "Lightweight PSR-7 and PSR-17 implementation"
    },
    "autoload": {
        "psr-4": {
            "Hval\\Nexi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hval\\Nexi\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
